 &control
    calculation='scf'
    restart_mode='from_scratch',
    prefix='FeO'
    pseudo_dir = './'
    outdir='./FeO'
    verbosity='high'
 /
 &system
    ibrav = 0,
    celldm(1) = 8.00,
    nat = 4,
    ntyp = 3,
    ecutwfc = 50
    nspin = 2
    starting_magnetization(1) =  0.5,
    starting_magnetization(2) = -0.5,
    occupations = 'smearing',
    smearing = 'gauss',
    degauss = 0.01,
    nbnd = 26,
    !starting_ns_eigenvalue(5,2,1) = 1.d0,
    !starting_ns_eigenvalue(5,1,2) = 1.d0

 /
 &electrons
    conv_thr =  1.d-8, 
    mixing_beta = 0.3
 /
ATOMIC_SPECIES
 Fe1  55.845  Fe_ONCV_PBE-1.2_wfc.upf
 Fe2  55.845  Fe_ONCV_PBE-1.2_wfc.upf
 O    15.999  O_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS {crystal}
Fe1      0.00000000     0.00000000     0.00000000
Fe2      0.50000000     0.50000000     0.50000000
O        0.25000000     0.25000000     0.25000000
O        0.75000000     0.75000000     0.75000000
CELL_PARAMETERS {alat}
   0.582729109   0.582729109   1.045799900
   0.582729109   1.045799900   0.582729109
   1.045799900   0.582729109   0.582729109
K_POINTS {automatic}
 3 3 3 0 0 0
HUBBARD {atomic}
U Fe1-3d 5.36
U Fe2-3d 5.36
&CONTROL
    calculation='scf'
    prefix='MnO'
    restart_mode='from_scratch'
    outdir='./MnO'
    pseudo_dir='./'

/
&system
    ibrav = 0, celldm(1) = 10.29
    nat = 4, ntyp = 3, nspin=2,
    ecutwfc = 50.0
    starting_magnetization(1)=  0.2,
    starting_magnetization(2)= -0.2,
    tot_magnetization = 0.0,
    nbnd=30, 
    occupations = 'smearing',
    smearing = 'gauss',
    degauss=0.01, 
    nosym = .true.
 /
 &electrons
    mixing_beta = 0.3,
    conv_thr = 1d-8
 /

CELL_PARAMETERS
0.288675 -0.166667 0.942809
0.000000 0.333333 0.942809
-0.288675 -0.166667 0.942809

ATOMIC_SPECIES
Mn1 54.93804   Mn_ONCV_PBE-1.2_wfc.upf
Mn2 54.93804   Mn_ONCV_PBE-1.2_wfc.upf
O  15.999   O_ONCV_PBE-1.2.upf

ATOMIC_POSITIONS crystal
Mn1  0.0000000000  0.0000000000  0.0000000000
Mn2  -0.5000000000  1.5000000000  -0.5000000000
O  0.7500000000  -0.2500000000  -0.2500000000
O  -0.7500000000  0.2500000000  0.2500000000

K_POINTS automatic
3 3 3 0 0 0

!HUBBARD {atomic}
